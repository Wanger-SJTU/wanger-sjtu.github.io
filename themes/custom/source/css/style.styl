/* ============================================
   Custom Theme - 简约黑白灰风格
   ============================================ */

/* CSS 变量 */
:root {
  --color-bg: #ffffff;
  --color-text: #1a1a1a;
  --color-text-secondary: #666666;
  --color-text-tertiary: #999999;
  --color-border: #e5e5e5;
  --color-accent: #000000;
  --color-accent-light: #333333;
  --color-card-bg: #fafafa;
  --color-hover: #f5f5f5;
  --color-code-bg: #f8f8f8;
  --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans SC", sans-serif;
  --font-mono: "SF Mono", Consolas, "Liberation Mono", Menlo, monospace;
  --max-width: 1400px;
  --content-width: 900px;
  --spacing-unit: 1rem;
  --radius: 4px;
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  --transition: 0.2s ease;
}

/* 暗黑模式 */
[data-theme="dark"] {
  --color-bg: #0a0a0a;
  --color-text: #e8e8e8;
  --color-text-secondary: #a0a0a0;
  --color-text-tertiary: #666666;
  --color-border: #2a2a2a;
  --color-accent: #ffffff;
  --color-accent-light: #cccccc;
  --color-card-bg: #141414;
  --color-hover: #1f1f1f;
  --color-code-bg: #1a1a1a;
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}

/* Reset & Base */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  font-size: 16px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-sans);
  background-color: var(--color-bg);
  color: var(--color-text);
  line-height: 1.7;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  transition: background-color var(--transition), color var(--transition);
}

a {
  color: var(--color-accent);
  text-decoration: none;
  transition: opacity var(--transition);
}

a:hover {
  opacity: 0.7;
}

/* Wiki Links - 双链样式 */
.wiki-link {
  position: relative;
  padding: 0 4px;
  border-radius: 3px;
  background: linear-gradient(to bottom, transparent 60%, var(--color-accent) 60%);
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-position: left bottom;
}

.wiki-link:hover {
  opacity: 1;
}

.wiki-link.broken {
  background: linear-gradient(to bottom, transparent 60%, var(--color-text-tertiary) 60%);
  cursor: help;
  opacity: 0.6;
}

img {
  max-width: 100%;
  height: auto;
}

/* Container */
.container {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 var(--spacing-unit);
}

/* ============================================
   Header - Fixed Navbar (amytis style)
   ============================================ */
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  background: var(--color-bg);
  border-bottom: 1px solid transparent;
  transition: all 0.3s ease;
}

.site-header.scrolled {
  background: rgba(255, 255, 255, 0.9);
  border-bottom-color: var(--color-border);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

[data-theme="dark"] .site-header.scrolled {
  background: rgba(10, 10, 10, 0.9);
}

.header-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1152px;
  margin: 0 auto;
  height: 64px;
  padding: 0 1.5rem;
}

.site-nav {
  display: flex;
  align-items: center;
  gap: 0;
}

.nav-link {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-secondary);
  padding: 20px 16px;
  transition: color 0.2s ease;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.nav-link:hover {
  color: var(--color-text);
}

.nav-link.active {
  color: var(--color-accent);
}

/* 知识图谱按钮样式 */
.nav-link-button {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white !important;
  padding: 8px 18px !important;
  border-radius: 20px;
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  text-transform: none;
  letter-spacing: normal;
}

.nav-link-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
  filter: brightness(1.1);
}

.nav-link-button.active {
  background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.5);
}

@media (max-width: 768px) {
  .nav-link-button {
    padding: 6px 14px !important;
    font-size: 0.8rem;
  }
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.header-action-btn {
  background: transparent;
  border: none;
  font-size: 1.1rem;
  cursor: pointer;
  padding: 8px;
  border-radius: 6px;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  color: var(--color-text);
}

.header-action-btn:hover {
  background: var(--color-hover);
}

.search-toggle,
.theme-toggle {
  background: transparent;
  border: none;
  font-size: 1.3rem;
  cursor: pointer;
  padding: 10px 16px;
  border-radius: 8px;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56px;
  height: 44px;
}

.search-toggle:hover,
.theme-toggle:hover {
  background: var(--color-hover);
}

.theme-toggle .icon-moon {
  display: none;
}

[data-theme="dark"] .theme-toggle .icon-sun {
  display: none;
}

[data-theme="dark"] .theme-toggle .icon-moon {
  display: inline;
}

/* Hamburger Menu Button */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: space-around;
  width: 24px;
  height: 20px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0;
  z-index: 60;
}

.hamburger-line {
  width: 24px;
  height: 2px;
  background: var(--color-text);
  transition: all 0.3s ease;
}

.hamburger.active .hamburger-line:nth-child(1) {
  transform: rotate(45deg) translate(5px, 5px);
}

.hamburger.active .hamburger-line:nth-child(2) {
  opacity: 0;
}

.hamburger.active .hamburger-line:nth-child(3) {
  transform: rotate(-45deg) translate(5px, -5px);
}

/* Mobile Menu */
.mobile-menu {
  position: fixed;
  top: 0;
  left: -280px;
  width: 280px;
  height: 100vh;
  background: var(--color-bg);
  z-index: 55;
  transition: left 0.3s ease;
  box-shadow: 2px 0 8px rgba(0, 0, 0, 0.1);
}

.mobile-menu.active {
  left: 0;
}

.mobile-nav {
  display: flex;
  flex-direction: column;
  padding: 80px 24px 24px;
}

.mobile-nav-link {
  font-size: 1rem;
  font-weight: 500;
  color: var(--color-text);
  padding: 16px 0;
  border-bottom: 1px solid var(--color-border);
  transition: color 0.2s ease;
}

.mobile-nav-link:hover {
  color: var(--color-accent);
}

.mobile-nav-link.active {
  color: var(--color-accent);
}

.mobile-action-btn {
  background: transparent;
  border: none;
  font-size: 1rem;
  cursor: pointer;
  padding: 16px 0;
  border-bottom: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--color-text);
  width: 100%;
  text-align: left;
}

.mobile-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 54;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.mobile-overlay.active {
  opacity: 1;
  visibility: visible;
}

/* Body padding for fixed header */
body {
  padding-top: 64px;
}

/* ============================================
   Main Content
   ============================================ */
.main-content {
  flex: 1;
  padding: 3rem 0;
}

/* Hero Section */
.hero {
  text-align: center;
  padding: 3rem 0;
  margin-bottom: 2rem;
}

.hero-title {
  font-size: 3rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
}

.hero-subtitle {
  font-size: 1.25rem;
  color: var(--color-text-secondary);
}

/* 首页两栏布局 */
.home-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: start;
}

.posts-main {
  min-width: 0;
}

.nonsense-sidebar {
  position: sticky;
  top: 90px;
}

/* Section */
.section-title {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
  letter-spacing: -0.02em;
}

/* ============================================
   Post Cards (Home)
   ============================================ */
.post-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}

.post-card {
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1.5rem;
  transition: transform var(--transition), box-shadow var(--transition);
}

.post-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}

.post-card .post-date {
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  margin-bottom: 0.5rem;
}

.post-card .post-title {
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 0.75rem;
}

.post-card .post-title a {
  color: var(--color-text);
}

.post-card .post-title a:hover {
  color: var(--color-accent);
  opacity: 1;
}

.post-card .post-excerpt {
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 1rem;
}

.post-card .post-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
}

.post-card .post-tags a {
  color: var(--color-text-secondary);
}

/* ============================================
   Post Page
   ============================================ */
.post-page {
  max-width: var(--content-width);
  margin: 0 auto;
}

.post-header {
  margin-bottom: 2rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--color-border);
}

.post-page .post-title {
  font-size: 2.5rem;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
}

.post-page .post-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  font-size: 0.9rem;
  color: var(--color-text-secondary);
}

.post-content {
  font-size: 1.1rem;
  line-height: 1.8;
  word-wrap: break-word;
  overflow-wrap: break-word;
  word-break: break-word;
}

.post-content h1,
.post-content h2,
.post-content h3,
.post-content h4 {
  margin-top: 2rem;
  margin-bottom: 1rem;
  font-weight: 600;
  letter-spacing: -0.01em;
  word-wrap: break-word;
  overflow-wrap: break-word;
  word-break: break-word;
  scroll-margin-top: 80px;
}

.post-content h2 {
  font-size: 1.5rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--color-border);
}

.post-content h3 {
  font-size: 1.25rem;
}

.post-content p {
  margin-bottom: 1.5rem;
  word-wrap: break-word;
  overflow-wrap: break-word;
  word-break: break-word;
}

.post-content strong,
.post-content b {
  font-weight: 700;
}

.post-content ul,
.post-content ol {
  margin-bottom: 1.5rem;
  padding-left: 1.5rem;
}

/* 目录导航移除序号 */
.post-content ul li:has(a[href^="#"]) {
  list-style: none;
}

.post-content ul:has(li:has(a[href^="#"])) {
  list-style: none;
  padding-left: 0;
}

.post-content li {
  margin-bottom: 0.5rem;
  word-wrap: break-word;
  overflow-wrap: break-word;
  word-break: break-word;
}

.post-content code {
  font-family: var(--font-mono);
  font-size: 0.9em;
  background: var(--color-code-bg);
  padding: 0.2em 0.4em;
  border-radius: 3px;
  word-wrap: break-word;
  overflow-wrap: break-word;
  word-break: break-all;
}

.post-content pre {
  background: var(--color-code-bg);
  padding: 1rem;
  border-radius: var(--radius);
  overflow-x: auto;
  margin-bottom: 1.5rem;
  -webkit-overflow-scrolling: touch;
  font-size: 0.85rem;
  line-height: 1.5;
}

.post-content pre code {
  background: none;
  padding: 0;
  white-space: pre;
  font-family: var(--font-mono);
  font-size: inherit;
}

/* Highlight.js 代码块样式 */
.highlight {
  background: var(--color-code-bg);
  border-radius: var(--radius);
  margin-bottom: 1.5rem;
  padding: 1rem;
}

.highlight pre {
  background: none;
  padding: 0;
  margin: 0;
  font-size: 0.85rem;
  line-height: 1.5;
}

.highlight code {
  font-family: var(--font-mono);
  font-size: inherit;
  background: none;
  white-space: pre;
  display: block;
}

/* 暗黑模式下的代码高亮颜色 */
[data-theme="dark"] .highlight {
  background: #1a1a1a;
}

[data-theme="dark"] .highlight .keyword,
[data-theme="dark"] .highlight .selector-tag,
[data-theme="dark"] .highlight .literal,
[data-theme="dark"] .highlight .title {
  color: #569cd6;
}

[data-theme="dark"] .highlight .string,
[data-theme="dark"] .highlight .attr-value {
  color: #ce9178;
}

[data-theme="dark"] .highlight .comment,
[data-theme="dark"] .highlight .quote {
  color: #6a9955;
  font-style: italic;
}

[data-theme="dark"] .highlight .number,
[data-theme="dark"] .highlight .symbol {
  color: #b5cea8;
}

[data-theme="dark"] .highlight .function,
[data-theme="dark"] .highlight .built_in {
  color: #dcdcaa;
}

[data-theme="dark"] .highlight .class,
[data-theme="dark"] .highlight .variable {
  color: #4ec9b0;
}

[data-theme="dark"] .highlight .operator,
[data-theme="dark"] .highlight .entity {
  color: #d4d4d4;
}

[data-theme="dark"] .highlight .tag,
[data-theme="dark"] .highlight .name {
  color: #569cd6;
}

[data-theme="dark"] .highlight .attribute {
  color: #9cdcfe;
}

[data-theme="dark"] .highlight .params {
  color: #d4d4d4;
}

/* 亮色模式下的代码高亮颜色 */
.highlight .keyword,
.highlight .selector-tag,
.highlight .literal,
.highlight .title {
  color: #0000ff;
  font-weight: 600;
}

.highlight .string,
.highlight .attr-value {
  color: #a31515;
}

.highlight .comment,
.highlight .quote {
  color: #008000;
  font-style: italic;
}

.highlight .number,
.highlight .symbol {
  color: #098658;
}

.highlight .function,
.highlight .built_in {
  color: #795e26;
}

.highlight .class,
.highlight .variable {
  color: #267f99;
}

.highlight .operator,
.highlight .entity {
  color: #000;
}

.highlight .tag,
.highlight .name {
  color: #800000;
}

.highlight .attribute {
  color: #ff0000;
}

.highlight .params {
  color: #000;
}

.post-content blockquote {
  border-left: 4px solid var(--color-accent);
  padding-left: 1rem;
  margin: 1.5rem 0;
  color: var(--color-text-secondary);
  font-style: italic;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.post-content img {
  border-radius: var(--radius);
  margin: 1.5rem 0;
  max-width: 100%;
  height: auto;
}

.post-content table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 1.5rem;
  display: block;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.post-content th,
.post-content td {
  border: 1px solid var(--color-border);
  padding: 0.75rem;
  text-align: left;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.post-content th {
  background: var(--color-card-bg);
  font-weight: 600;
}

.post-footer {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.post-tags .tag {
  background: var(--color-hover);
  padding: 0.25rem 0.75rem;
  border-radius: var(--radius);
  font-size: 0.85rem;
  color: var(--color-text-secondary);
}

.post-nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-top: 2rem;
}

.nav-prev,
.nav-next {
  padding: 1rem;
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
}

.nav-next {
  text-align: right;
}

.nav-label {
  display: block;
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  margin-bottom: 0.25rem;
}

.nav-title {
  font-weight: 500;
}

.nav-placeholder {
  visibility: hidden;
}

/* ============================================
   Archive Page
   ============================================ */
.archive-page {
  max-width: 800px;
  margin: 0 auto;
}

.archive-stats {
  margin-bottom: 2rem;
  color: var(--color-text-secondary);
}

.archive-year {
  margin-bottom: 2rem;
}

.year-header {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--color-accent);
}

.archive-posts {
  list-style: none;
}

.archive-item {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--color-border);
}

.archive-date {
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  min-width: 60px;
}

.archive-title {
  flex: 1;
  font-weight: 500;
}

.archive-category {
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
}

/* ============================================
   Tag Page
   ============================================ */
.tag-page {
  max-width: 1000px;
  margin: 0 auto;
}

.tag-stats {
  text-align: center;
  margin-bottom: 2.5rem;
  color: var(--color-text-secondary);
  font-size: 0.95rem;
}

.stat-number {
  font-weight: 600;
  color: var(--color-accent);
}

.tag-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 1rem;
  margin-bottom: 3rem;
}

.tag-card {
  display: block;
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 1rem;
  transition: all var(--transition);
  cursor: pointer;
}

.tag-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}

.tag-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0.5rem;
  margin-bottom: 0.5rem;
}

.tag-card .tag-name {
  font-size: 1rem;
  font-weight: 500;
  color: var(--color-text);
  word-break: break-word;
  flex: 1;
}

.tag-card .tag-count {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-accent);
  line-height: 1;
  flex-shrink: 0;
}

.tag-card-footer {
  font-size: 0.8rem;
  color: var(--color-text-tertiary);
}

.tag-posts {
  margin-top: 2rem;
}

.tag-posts .post-count {
  font-size: 0.9rem;
  font-weight: 400;
  color: var(--color-text-secondary);
  margin-left: 0.5rem;
}

/* Responsive */
@media (max-width: 600px) {
  .tag-grid {
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
  }

  .tag-card {
    padding: 0.875rem;
  }

  .tag-card .tag-count {
    font-size: 1.25rem;
  }
}

.post-list {
  list-style: none;
}

.post-list-item {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--color-border);
}

.post-list-item .post-date {
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  min-width: 90px;
}

/* ============================================
   Page Template
   ============================================ */
.page-content {
  max-width: var(--content-width);
  margin: 0 auto;
}

.page-header {
  margin-bottom: 2rem;
}

.page-title {
  font-size: 2rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.page-body {
  font-size: 1.1rem;
  line-height: 1.8;
}

/* ============================================
   Search Modal
   ============================================ */
.search-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  align-items: flex-start;
  justify-content: center;
  padding-top: 15vh;
}

.search-modal.active {
  display: flex;
}

.search-modal-content {
  background: var(--color-bg);
  width: 100%;
  max-width: 600px;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
}

/* ============================================
   Mermaid Modal
   ============================================ */
.mermaid-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  z-index: 1001;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.mermaid-modal.active {
  display: flex;
}

.mermaid-modal-content {
  background: var(--color-bg);
  border-radius: 8px;
  padding: 2rem;
  max-width: 90vw;
  max-height: 90vh;
  overflow: auto;
  position: relative;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  transform-origin: center center;
  transition: transform 0.1s ease-out;
}

.mermaid-modal-close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  width: 36px;
  height: 36px;
  border: none;
  background: var(--color-hover);
  border-radius: 50%;
  cursor: pointer;
  font-size: 20px;
  line-height: 1;
  color: var(--color-text);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
  z-index: 10;
}

.mermaid-modal-close:hover {
  background: var(--color-border);
}

/* Make mermaid diagrams clickable */
pre.mermaid {
  cursor: pointer;
  position: relative;
  padding: 1rem;
  background: var(--color-code-bg);
  border-radius: 4px;
  border: 1px solid var(--color-border);
  transition: border-color 0.2s, box-shadow 0.2s;
}

pre.mermaid:hover {
  border-color: var(--color-accent);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

pre.mermaid::after {
  content: '点击放大';
  position: absolute;
  top: 0.5rem;
  right: 0.5rem;
  padding: 0.25rem 0.5rem;
  font-size: 12px;
  background: var(--color-accent);
  color: var(--color-bg);
  border-radius: 4px;
  opacity: 0;
  transition: opacity 0.2s;
  pointer-events: none;
}

pre.mermaid:hover::after {
  opacity: 1;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--color-border);
}

.search-input {
  flex: 1;
  font-size: 1.1rem;
  border: none;
  background: transparent;
  color: var(--color-text);
  outline: none;
}

.search-input::placeholder {
  color: var(--color-text-tertiary);
}

.search-close {
  background: none;
  border: none;
  font-size: 1.5rem;
  color: var(--color-text-secondary);
  cursor: pointer;
  padding: 0.25rem;
  line-height: 1;
}

.search-close:hover {
  color: var(--color-text);
}

.search-results {
  max-height: 400px;
  overflow-y: auto;
}

.search-empty {
  padding: 2rem;
  text-align: center;
  color: var(--color-text-secondary);
}

.search-result-item {
  display: block;
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--color-border);
  transition: background-color var(--transition);
}

.search-result-item:hover {
  background: var(--color-hover);
}

.search-result-item:last-child {
  border-bottom: none;
}

.search-result-title {
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.search-result-excerpt {
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.search-result-item mark {
  background: rgba(255, 200, 0, 0.3);
  color: inherit;
  padding: 0 0.1em;
}

/* ============================================
   Pagination
   ============================================ */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.5rem;
  margin-top: 3rem;
}

.pagination .page-number,
.pagination .extend {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 2.5rem;
  height: 2.5rem;
  padding: 0 0.75rem;
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  font-size: 0.9rem;
  color: var(--color-text);
  transition: background-color var(--transition), border-color var(--transition);
}

.pagination .page-number:hover,
.pagination .extend:hover {
  background: var(--color-hover);
  opacity: 1;
}

.pagination .page-number.current {
  background: var(--color-accent);
  color: var(--color-bg);
  border-color: var(--color-accent);
}

/* ============================================
   Footer
   ============================================ */
.site-footer {
  border-top: 1px solid var(--color-border);
  margin-top: auto;
}

.footer-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 0;
  flex-wrap: wrap;
  gap: 1rem;
}

.footer-content {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.copyright,
.powered-by {
  font-size: 0.85rem;
  color: var(--color-text-secondary);
}

.powered-by a {
  color: var(--color-text-secondary);
}

.powered-by a:hover {
  color: var(--color-accent);
}

/* ============================================
   Responsive
   ============================================ */
@media (max-width: 768px) {
  .site-nav {
    display: none;
  }
  
  .header-actions {
    display: none;
  }
  
  .hamburger {
    display: flex;
  }
  
  .header-container {
    padding: 0 1rem;
  }
  
  .hero-title {
    font-size: 2rem;
  }
  
  .post-cards {
    grid-template-columns: 1fr;
  }
  
  .post-page {
    width: 100%;
    max-width: 100%;
  }
  
  .post-page .post-title {
    font-size: 1.75rem;
  }
  
  .post-content {
    font-size: 1rem;
    width: 100%;
    max-width: 100%;
  }
  
  .post-content h2 {
    font-size: 1.3rem;
  }
  
  .post-content h3 {
    font-size: 1.15rem;
  }
  
  .post-content pre {
    padding: 0.75rem;
    font-size: 0.85rem;
    white-space: pre;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .post-content pre code {
    white-space: pre;
  }
  
  .post-content code {
    word-break: break-all;
    overflow-wrap: break-word;
  }
  
  .post-content ul,
  .post-content ol {
    padding-left: 1rem;
  }
  
  .post-content table {
    display: block;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  
  .post-content a {
    word-wrap: break-word;
    overflow-wrap: break-word;
    word-break: break-all;
  }
  
  .post-nav {
    grid-template-columns: 1fr;
  }
  
  .nav-next {
    text-align: left;
  }
  
  .archive-item {
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .archive-date {
    min-width: auto;
  }
  
  .footer-inner {
    flex-direction: column;
    text-align: center;
  }
}

@media (max-width: 480px) {
  html {
    font-size: 14px;
  }
  
  .container {
    padding: 0 0.75rem;
  }
  
  .header-inner {
    gap: 0.5rem;
  }
  
  .site-nav {
    gap: 0.75rem;
  }
  
  .nav-link {
    font-size: 1.2rem;
  }
}

/* ============================================
   Nonsense Section (废话栏目)
   ============================================ */
.nonsense-section {
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1.5rem;
}

.nonsense-section .nonsense-title {
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-text-tertiary);
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-border);
}

.nonsense-list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  position: relative;
  padding-left: 1.5rem;
}

.nonsense-list::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.5rem;
  bottom: 0.5rem;
  width: 2px;
  background: var(--color-border);
}

.nonsense-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 0.75rem 0;
  position: relative;
  transition: background-color var(--transition);
}

.nonsense-item::before {
  content: '';
  position: absolute;
  left: -1.5rem;
  top: 1rem;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-bg);
  border: 2px solid var(--color-accent);
  z-index: 1;
}

.nonsense-item:hover {
  background: var(--color-hover);
  margin: 0 -0.5rem;
  padding-left: 0.5rem;
  padding-right: 0.5rem;
  border-radius: var(--radius);
}

.nonsense-item:hover::before {
  background: var(--color-accent);
}

.nonsense-date {
  font-size: 0.8rem;
  color: var(--color-text-tertiary);
  min-width: 40px;
  font-family: var(--font-mono);
  flex-shrink: 0;
}

.nonsense-content {
  flex: 1;
  min-width: 0;
}

.nonsense-title-text {
  font-size: 0.95rem;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 0.25rem;
}

.nonsense-title-text a {
  color: var(--color-text);
}

.nonsense-title-text a:hover {
  color: var(--color-accent);
  opacity: 1;
}

.nonsense-excerpt {
  font-size: 0.85rem;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin: 0;
}

.nonsense-tags {
  margin-top: 0.5rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.nonsense-tag {
  font-size: 0.75rem;
  color: var(--color-accent);
  background: var(--color-hover);
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  transition: background-color var(--transition);
}

.nonsense-tag:hover {
  background: var(--color-accent);
  color: var(--color-bg);
}

.nonsense-title-text a:hover {
  color: var(--color-accent);
  opacity: 1;
}

@media (max-width: 768px) {
  .nonsense-section {
    padding: 1rem;
  }
  
  .nonsense-item {
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .nonsense-date {
    min-width: auto;
  }
}

/* 首页两栏布局响应式 */
@media (max-width: 900px) {
  .home-layout {
    grid-template-columns: 1fr;
  }
  
  .nonsense-sidebar {
    position: static;
  }
  
  .nonsense-section {
    margin-bottom: 2rem;
  }
}

/* ============================================
   Related Posts Sidebar
   ============================================ */
.post-layout {
  display: flex;
  gap: 2rem;
  max-width: var(--max-width);
  margin: 0 auto;
  align-items: flex-start;
}

.post-toc-sidebar {
  width: 220px;
  flex-shrink: 0;
  position: sticky;
  top: 5rem;
  align-self: flex-start;
}

.post-layout .post-page {
  flex: 1;
  min-width: 0;
  max-width: var(--content-width);
}

.post-right-sidebar {
  width: 280px;
  flex-shrink: 0;
  position: sticky;
  top: 5rem;
  align-self: flex-start;
}

.post-sidebar {
  width: 280px;
  flex-shrink: 0;
  position: sticky;
  top: 5rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.sidebar-widget {
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1.25rem;
}

.related-posts-widget {
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1.25rem;
}

.toc-widget {
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1.25rem;
  max-height: calc(100vh - 8rem);
  overflow-y: auto;
}

.toc-list {
  list-style: none !important;
  margin: 0;
  padding: 0;
}

/* 强制移除有序列表的序号 */
ol.toc-list {
  list-style: none !important;
  padding-left: 0 !important;
}

ol.toc-list > li {
  list-style: none !important;
}

ol.toc-list li,
ol.toc-list > li {
  list-style: none !important;
  padding-left: 0 !important;
}

/* 移除所有嵌套的序号 */
ol.toc-list-child {
  list-style: none !important;
  padding-left: 1rem !important;
}

ol.toc-list-child li {
  list-style: none !important;
}

ol.toc-list li {
  margin-bottom: 0.5rem;
}

/* 调整一级标题样式，使其与二级标题完全一致 */
.toc-list-item-level-1,
.toc-list-item-level-1 > a,
.toc-list-item-level-1 .toc-list-link,
.toc-list-item-level-1 .toc-list-text {
  font-size: 0.875rem !important;
  font-weight: normal !important;
  color: var(--color-text-secondary) !important;
}

/* 确保一级标题链接不加粗 */
.toc-list-item-level-1 a,
.toc-list-item-level-1 .toc-list-link {
  font-weight: normal !important;
}

/* 确保一级标题不显示任何列表标记 */
.toc-list-item-level-1,
.toc-list-item-level-1::marker {
  list-style: none !important;
  list-style-type: none !important;
}

/* 调整一级标题的嵌套列表缩进 */
.toc-list-item-level-1 > .toc-list-child {
  padding-left: 0 !important;
}

.toc-list li {
  margin-bottom: 0.5rem;
}

.toc-list li a {
  display: block;
  color: var(--color-text-secondary);
  text-decoration: none;
  font-size: 0.875rem;
  line-height: 1.5;
  padding: 0.25rem 0.5rem;
  border-radius: 3px;
  transition: all var(--transition);
}

.toc-list li a:hover {
  color: var(--color-accent);
  background: var(--color-hover);
}

.toc-list li a.active {
  color: var(--color-accent);
  background: var(--color-hover);
  font-weight: 500;
}

.toc-list ul {
  list-style: none;
  margin: 0.5rem 0 0.5rem 1rem;
  padding: 0;
}

.toc-list ul li a {
  font-size: 0.8125rem;
  color: var(--color-text-tertiary);
}

.widget-title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text);
}

.related-posts-list {
  list-style: none;
}

.related-post-item {
  margin-bottom: 0.75rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-border);
}

.related-post-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.related-post-link {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.related-post-link:hover {
  opacity: 1;
}

.related-post-title {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--color-text);
  line-height: 1.4;
  transition: color var(--transition);
}

.related-post-link:hover .related-post-title {
  color: var(--color-accent);
}

.related-post-date {
  font-size: 0.8rem;
  color: var(--color-text-tertiary);
}

/* 文章图谱 Widget */
.article-graph-widget {
  display: flex;
  flex-direction: column;
}

.article-graph-widget #article-graph-sidebar {
  width: 100%;
  height: 280px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  background: var(--color-bg);
}

/* 响应式布局 */
@media (max-width: 1024px) {
  .post-layout {
    flex-direction: column;
  }

  .post-toc-sidebar {
    width: 100%;
    position: static;
    order: -1;
    margin-bottom: 2rem;
  }

  .post-right-sidebar {
    width: 100%;
    position: static;
    order: 1;
    margin-top: 2rem;
  }

  .post-sidebar {
    width: 100%;
    position: static;
    margin-top: 2rem;
  }

  .sidebar-widget {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .related-posts-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  
  .related-post-item {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
    background: var(--color-hover);
    padding: 0.75rem;
    border-radius: var(--radius);
  }
}
