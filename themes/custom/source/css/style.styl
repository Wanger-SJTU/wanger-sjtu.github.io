/* ============================================
   Custom Theme - 简约黑白灰风格
   ============================================ */

/* CSS 变量 */
:root {
  --color-bg: #ffffff;
  --color-text: #1a1a1a;
  --color-text-secondary: #666666;
  --color-text-tertiary: #999999;
  --color-border: #e5e5e5;
  --color-accent: #000000;
  --color-accent-light: #333333;
  --color-card-bg: #fafafa;
  --color-hover: #f5f5f5;
  --color-code-bg: #f8f8f8;
  --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans SC", sans-serif;
  --font-mono: "SF Mono", Consolas, "Liberation Mono", Menlo, monospace;
  --max-width: 1200px;
  --content-width: 720px;
  --spacing-unit: 1rem;
  --radius: 4px;
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  --transition: 0.2s ease;
}

/* 暗黑模式 */
[data-theme="dark"] {
  --color-bg: #0a0a0a;
  --color-text: #e8e8e8;
  --color-text-secondary: #a0a0a0;
  --color-text-tertiary: #666666;
  --color-border: #2a2a2a;
  --color-accent: #ffffff;
  --color-accent-light: #cccccc;
  --color-card-bg: #141414;
  --color-hover: #1f1f1f;
  --color-code-bg: #1a1a1a;
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}

/* Reset & Base */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  font-size: 16px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-sans);
  background-color: var(--color-bg);
  color: var(--color-text);
  line-height: 1.7;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  transition: background-color var(--transition), color var(--transition);
}

a {
  color: var(--color-accent);
  text-decoration: none;
  transition: opacity var(--transition);
}

a:hover {
  opacity: 0.7;
}

img {
  max-width: 100%;
  height: auto;
}

/* Container */
.container {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 var(--spacing-unit);
}

/* ============================================
   Header - 全宽导航栏
   ============================================ */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  width: 100%;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72px;
  gap: 2rem;
  flex-wrap: nowrap;
  padding: 0 var(--spacing-unit);
  width: 100%;
}

.site-nav {
  display: flex;
  align-items: center;
  gap: 2.5rem;
  justify-content: center;
}

.nav-link {
  position: relative;
  font-size: 2rem;
  font-weight: 500;
  color: var(--color-text-secondary);
  padding: 0.5rem 0;
  transition: color 0.3s ease;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 2px;
  background: var(--color-accent);
  transition: all 0.3s ease;
  transform: translateX(-50%);
}

.nav-link:hover {
  color: var(--color-text);
}

.nav-link:hover::after {
  width: 100%;
}

.nav-link.active {
  color: var(--color-accent);
  font-weight: 600;
}

.nav-link.active::after {
  width: 100%;
  background: var(--color-accent);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
}

.search-toggle,
.theme-toggle {
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  font-size: 1.1rem;
  cursor: pointer;
  padding: 0.6rem;
  border-radius: 50%;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  flex-shrink: 0;
}

.search-toggle:hover,
.theme-toggle:hover {
  background: var(--color-hover);
  border-color: var(--color-accent);
  transform: scale(1.1);
}

.theme-toggle .icon-moon {
  display: none;
}

[data-theme="dark"] .theme-toggle .icon-sun {
  display: none;
}

[data-theme="dark"] .theme-toggle .icon-moon {
  display: inline;
}

/* ============================================
   Main Content
   ============================================ */
.main-content {
  flex: 1;
  padding: 3rem 0;
}

/* Hero Section */
.hero {
  text-align: center;
  padding: 3rem 0;
  margin-bottom: 2rem;
}

.hero-title {
  font-size: 3rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
}

.hero-subtitle {
  font-size: 1.25rem;
  color: var(--color-text-secondary);
}

/* 首页两栏布局 */
.home-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: start;
}

.posts-main {
  min-width: 0;
}

.nonsense-sidebar {
  position: sticky;
  top: 90px;
}

/* Section */
.section-title {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
  letter-spacing: -0.02em;
}

/* ============================================
   Post Cards (Home)
   ============================================ */
.post-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}

.post-card {
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1.5rem;
  transition: transform var(--transition), box-shadow var(--transition);
}

.post-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}

.post-card .post-date {
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  margin-bottom: 0.5rem;
}

.post-card .post-title {
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 0.75rem;
}

.post-card .post-title a {
  color: var(--color-text);
}

.post-card .post-title a:hover {
  color: var(--color-accent);
  opacity: 1;
}

.post-card .post-excerpt {
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 1rem;
}

.post-card .post-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
}

.post-card .post-tags a {
  color: var(--color-text-secondary);
}

/* ============================================
   Post Page
   ============================================ */
.post-page {
  max-width: var(--content-width);
  margin: 0 auto;
}

.post-header {
  margin-bottom: 2rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--color-border);
}

.post-page .post-title {
  font-size: 2.5rem;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
}

.post-page .post-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  font-size: 0.9rem;
  color: var(--color-text-secondary);
}

.post-content {
  font-size: 1.1rem;
  line-height: 1.8;
}

.post-content h1,
.post-content h2,
.post-content h3,
.post-content h4 {
  margin-top: 2rem;
  margin-bottom: 1rem;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.post-content h2 {
  font-size: 1.5rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--color-border);
}

.post-content h3 {
  font-size: 1.25rem;
}

.post-content p {
  margin-bottom: 1.5rem;
}

.post-content ul,
.post-content ol {
  margin-bottom: 1.5rem;
  padding-left: 1.5rem;
}

.post-content li {
  margin-bottom: 0.5rem;
}

.post-content code {
  font-family: var(--font-mono);
  font-size: 0.9em;
  background: var(--color-code-bg);
  padding: 0.2em 0.4em;
  border-radius: 3px;
}

.post-content pre {
  background: var(--color-code-bg);
  padding: 1rem;
  border-radius: var(--radius);
  overflow-x: auto;
  margin-bottom: 1.5rem;
}

.post-content pre code {
  background: none;
  padding: 0;
}

.post-content blockquote {
  border-left: 4px solid var(--color-accent);
  padding-left: 1rem;
  margin: 1.5rem 0;
  color: var(--color-text-secondary);
  font-style: italic;
}

.post-content img {
  border-radius: var(--radius);
  margin: 1.5rem 0;
}

.post-content table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 1.5rem;
}

.post-content th,
.post-content td {
  border: 1px solid var(--color-border);
  padding: 0.75rem;
  text-align: left;
}

.post-content th {
  background: var(--color-card-bg);
  font-weight: 600;
}

.post-footer {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.post-tags .tag {
  background: var(--color-hover);
  padding: 0.25rem 0.75rem;
  border-radius: var(--radius);
  font-size: 0.85rem;
  color: var(--color-text-secondary);
}

.post-nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-top: 2rem;
}

.nav-prev,
.nav-next {
  padding: 1rem;
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
}

.nav-next {
  text-align: right;
}

.nav-label {
  display: block;
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  margin-bottom: 0.25rem;
}

.nav-title {
  font-weight: 500;
}

.nav-placeholder {
  visibility: hidden;
}

/* ============================================
   Archive Page
   ============================================ */
.archive-page {
  max-width: 800px;
  margin: 0 auto;
}

.archive-stats {
  margin-bottom: 2rem;
  color: var(--color-text-secondary);
}

.archive-year {
  margin-bottom: 2rem;
}

.year-header {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--color-accent);
}

.archive-posts {
  list-style: none;
}

.archive-item {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--color-border);
}

.archive-date {
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  min-width: 60px;
}

.archive-title {
  flex: 1;
  font-weight: 500;
}

.archive-category {
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
}

/* ============================================
   Tag Page
   ============================================ */
.tag-page {
  max-width: 800px;
  margin: 0 auto;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 3rem;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.5rem 1rem;
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  transition: background-color var(--transition), transform var(--transition);
}

.tag-item:hover {
  background: var(--color-hover);
  transform: translateY(-1px);
  opacity: 1;
}

.tag-count {
  font-size: 0.75em;
  color: var(--color-text-tertiary);
}

.tag-posts {
  margin-top: 2rem;
}

.tag-posts .post-count {
  font-size: 0.9rem;
  font-weight: 400;
  color: var(--color-text-secondary);
  margin-left: 0.5rem;
}

.post-list {
  list-style: none;
}

.post-list-item {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--color-border);
}

.post-list-item .post-date {
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  min-width: 90px;
}

/* ============================================
   Page Template
   ============================================ */
.page-content {
  max-width: var(--content-width);
  margin: 0 auto;
}

.page-header {
  margin-bottom: 2rem;
}

.page-title {
  font-size: 2rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.page-body {
  font-size: 1.1rem;
  line-height: 1.8;
}

/* ============================================
   Search Modal
   ============================================ */
.search-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  align-items: flex-start;
  justify-content: center;
  padding-top: 15vh;
}

.search-modal.active {
  display: flex;
}

.search-modal-content {
  background: var(--color-bg);
  width: 100%;
  max-width: 600px;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--color-border);
}

.search-input {
  flex: 1;
  font-size: 1.1rem;
  border: none;
  background: transparent;
  color: var(--color-text);
  outline: none;
}

.search-input::placeholder {
  color: var(--color-text-tertiary);
}

.search-close {
  background: none;
  border: none;
  font-size: 1.5rem;
  color: var(--color-text-secondary);
  cursor: pointer;
  padding: 0.25rem;
  line-height: 1;
}

.search-close:hover {
  color: var(--color-text);
}

.search-results {
  max-height: 400px;
  overflow-y: auto;
}

.search-empty {
  padding: 2rem;
  text-align: center;
  color: var(--color-text-secondary);
}

.search-result-item {
  display: block;
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--color-border);
  transition: background-color var(--transition);
}

.search-result-item:hover {
  background: var(--color-hover);
}

.search-result-item:last-child {
  border-bottom: none;
}

.search-result-title {
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.search-result-excerpt {
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.search-result-item mark {
  background: rgba(255, 200, 0, 0.3);
  color: inherit;
  padding: 0 0.1em;
}

/* ============================================
   Pagination
   ============================================ */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.5rem;
  margin-top: 3rem;
}

.pagination .page-number,
.pagination .extend {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 2.5rem;
  height: 2.5rem;
  padding: 0 0.75rem;
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  font-size: 0.9rem;
  color: var(--color-text);
  transition: background-color var(--transition), border-color var(--transition);
}

.pagination .page-number:hover,
.pagination .extend:hover {
  background: var(--color-hover);
  opacity: 1;
}

.pagination .page-number.current {
  background: var(--color-accent);
  color: var(--color-bg);
  border-color: var(--color-accent);
}

/* ============================================
   Footer
   ============================================ */
.site-footer {
  border-top: 1px solid var(--color-border);
  margin-top: auto;
}

.footer-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 0;
  flex-wrap: wrap;
  gap: 1rem;
}

.footer-content {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.copyright,
.powered-by {
  font-size: 0.85rem;
  color: var(--color-text-secondary);
}

.powered-by a {
  color: var(--color-text-secondary);
}

.powered-by a:hover {
  color: var(--color-accent);
}

/* ============================================
   Responsive
   ============================================ */
@media (max-width: 768px) {
  .header-inner {
    flex-wrap: wrap;
    height: auto;
    padding: 1rem 0;
    gap: 1rem;
  }
  
  .site-nav {
    order: 2;
    width: 100%;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }
  
  .nav-link {
    font-size: 1.9rem;
  }
  
  .header-actions {
    order: 1;
    margin-left: auto;
  }
  
  .search-toggle,
  .theme-toggle {
    width: 36px;
    height: 36px;
    font-size: 1rem;
  }
  
  .hero-title {
    font-size: 2rem;
  }
  
  .post-cards {
    grid-template-columns: 1fr;
  }
  
  .post-page .post-title {
    font-size: 1.75rem;
  }
  
  .post-nav {
    grid-template-columns: 1fr;
  }
  
  .nav-next {
    text-align: left;
  }
  
  .archive-item {
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .archive-date {
    min-width: auto;
  }
  
  .footer-inner {
    flex-direction: column;
    text-align: center;
  }
}

@media (max-width: 480px) {
  html {
    font-size: 14px;
  }
  
  .container {
    padding: 0 0.75rem;
  }
  
  .site-nav {
    gap: 1rem;
  }
  
  .nav-link {
    font-size: 1.8rem;
  }
}

/* ============================================
   Nonsense Section (废话栏目)
   ============================================ */
.nonsense-section {
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1.5rem;
}

.nonsense-section .nonsense-title {
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-text-tertiary);
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-border);
}

.nonsense-list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  position: relative;
  padding-left: 1.5rem;
}

.nonsense-list::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.5rem;
  bottom: 0.5rem;
  width: 2px;
  background: var(--color-border);
}

.nonsense-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 0.75rem 0;
  position: relative;
  transition: background-color var(--transition);
}

.nonsense-item::before {
  content: '';
  position: absolute;
  left: -1.5rem;
  top: 1rem;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-bg);
  border: 2px solid var(--color-accent);
  z-index: 1;
}

.nonsense-item:hover {
  background: var(--color-hover);
  margin: 0 -0.5rem;
  padding-left: 0.5rem;
  padding-right: 0.5rem;
  border-radius: var(--radius);
}

.nonsense-item:hover::before {
  background: var(--color-accent);
}

.nonsense-date {
  font-size: 0.8rem;
  color: var(--color-text-tertiary);
  min-width: 40px;
  font-family: var(--font-mono);
  flex-shrink: 0;
}

.nonsense-content {
  flex: 1;
  min-width: 0;
}

.nonsense-title-text {
  font-size: 0.95rem;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 0.25rem;
}

.nonsense-title-text a {
  color: var(--color-text);
}

.nonsense-title-text a:hover {
  color: var(--color-accent);
  opacity: 1;
}

.nonsense-excerpt {
  font-size: 0.85rem;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin: 0;
}

.nonsense-title-text a:hover {
  color: var(--color-accent);
  opacity: 1;
}

@media (max-width: 768px) {
  .nonsense-section {
    padding: 1rem;
  }
  
  .nonsense-item {
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .nonsense-date {
    min-width: auto;
  }
}

/* 首页两栏布局响应式 */
@media (max-width: 900px) {
  .home-layout {
    grid-template-columns: 1fr;
  }
  
  .nonsense-sidebar {
    position: static;
  }
  
  .nonsense-section {
    margin-bottom: 2rem;
  }
}

/* ============================================
   Related Posts Sidebar
   ============================================ */
.post-layout {
  display: flex;
  gap: 2rem;
  max-width: var(--max-width);
  margin: 0 auto;
  align-items: flex-start;
}

.post-layout .post-page {
  flex: 1;
  min-width: 0;
  max-width: var(--content-width);
}

.related-posts-sidebar {
  width: 280px;
  flex-shrink: 0;
  position: sticky;
  top: 5rem;
}

.related-posts-widget {
  background: var(--color-card-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1.25rem;
}

.widget-title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text);
}

.related-posts-list {
  list-style: none;
}

.related-post-item {
  margin-bottom: 0.75rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-border);
}

.related-post-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.related-post-link {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.related-post-link:hover {
  opacity: 1;
}

.related-post-title {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--color-text);
  line-height: 1.4;
  transition: color var(--transition);
}

.related-post-link:hover .related-post-title {
  color: var(--color-accent);
}

.related-post-date {
  font-size: 0.8rem;
  color: var(--color-text-tertiary);
}

/* 响应式布局 */
@media (max-width: 1024px) {
  .post-layout {
    flex-direction: column;
  }
  
  .related-posts-sidebar {
    width: 100%;
    position: static;
    margin-top: 2rem;
  }
  
  .related-posts-widget {
    max-width: var(--content-width);
    margin: 0 auto;
  }
  
  .related-posts-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  
  .related-post-item {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
    background: var(--color-hover);
    padding: 0.75rem;
    border-radius: var(--radius);
  }
}
