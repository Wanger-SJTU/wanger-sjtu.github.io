<%
// 获取 flows 页面数据
var flowsPage = site.pages.findOne({path: 'flows'});
var flowItems = [];

if (!flowsPage) {
  // 如果找不到，尝试遍历所有页面查找
  site.pages.each(function(page) {
    if (page.flows && page.flows.length > 0) {
      flowsPage = page;
      return false; // 停止遍历
    }
  });
}

if (flowsPage && flowsPage.flows) {
  flowItems = flowsPage.flows.slice().sort(function(a, b) {
    return new Date(b.date) - new Date(a.date);
  }).slice(0, 5);
}
%>

<% if (flowItems.length > 0) { %>
<section class="nonsense-section">
  <h2 class="section-title nonsense-title">
    <a href="<%= url_for('/flows') %>" style="text-decoration: none; color: inherit;">废话</a>
  </h2>
  <div class="nonsense-list">
    <% flowItems.forEach(function(item) { %>
    <article class="nonsense-item" data-date="<%= date(item.date, 'YYYY-MM-DD') %>">
      <time class="nonsense-date" datetime="<%= date(item.date, 'YYYY-MM-DD') %>">
        <%= date(item.date, 'MM.DD') %>
      </time>
      <div class="nonsense-content">
        <% if (item.title) { %>
        <h3 class="nonsense-title-text"><%= item.title %></h3>
        <% } %>
        <% if (item.text) { %>
        <p class="nonsense-excerpt"><%= item.text.substring(0, 80) %><% if (item.text.length > 80) { %>...<% } %></p>
        <% } %>
        <% if (item.tags && item.tags.length) { %>
        <div class="nonsense-tags">
          <% item.tags.forEach(function(tag) { %>
          <span class="nonsense-tag">#<%= tag %></span>
          <% }); %>
        </div>
        <% } %>
      </div>
    </article>
    <% }); %>
  </div>
</section>
<% } %>
