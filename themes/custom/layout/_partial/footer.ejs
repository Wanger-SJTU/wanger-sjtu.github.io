  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-content">
        <p class="copyright">
          © <%= theme.footer && theme.footer.since ? theme.footer.since + '-' : '' %><%= new Date().getFullYear() %> 
          <%= theme.footer && theme.footer.copyright ? theme.footer.copyright : config.author || config.title %>
        </p>
        
        <% if (theme.social) { %>
        <div class="social-links">
          <% if (theme.social.github) { %>
          <a href="<%= theme.social.github %>" target="_blank" rel="noopener noreferrer" class="social-link">GitHub</a>
          <% } %>
          <% if (theme.social.email) { %>
          <a href="<%= theme.social.email %>" class="social-link">Email</a>
          <% } %>
          <% if (theme.social.weibo) { %>
          <a href="<%= theme.social.weibo %>" target="_blank" rel="noopener noreferrer" class="social-link">微博</a>
          <% } %>
        </div>
        <% } %>
        
        <% if (theme.rss) { %>
        <a href="<%= url_for('/atom.xml') %>" class="rss-link">RSS</a>
        <% } %>
      </div>
      
      <p class="powered-by">Powered by <a href="https://hexo.io" target="_blank" rel="noopener">Hexo</a></p>
    </div>
  </footer>
