<div class="flow-page">
  <h1><%- page.title %></h1>
  <% if (page.description) { %>
  <p class="flow-description"><%- page.description %></p>
  <% } %>

  <div class="flow-layout">
    <div class="calendar-sidebar">
      <div class="calendar-container">
        <div class="calendar-header">
          <button class="calendar-nav" id="prevMonth">&lsaquo;</button>
          <h3 class="calendar-title" id="calendarTitle"></h3>
          <button class="calendar-nav" id="nextMonth">&rsaquo;</button>
        </div>
        <div class="calendar-grid">
          <div class="calendar-weekdays">
            <span>日</span><span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span>
          </div>
          <div class="calendar-days" id="calendarDays"></div>
        </div>
        <div class="filter-status" id="filterStatus" style="display: none;">
          <span class="filter-text" id="filterText"></span>
          <button class="clear-filter-btn" id="clearFilter">清除</button>
        </div>
      </div>
    </div>

    <div class="timeline-wrapper">
      <div class="timeline" id="timeline">
        <%
          var flowPages = [];
          site.pages.each(function(p) {
            if (p.source && p.source.indexOf('flows/') === 0 && p.source !== 'flows/index.md') {
              flowPages.push(p);
            }
          });
          flowPages.sort(function(a, b) {
            return new Date(b.date) - new Date(a.date);
          });
        %>
        <% flowPages.forEach(function(p) { %>
          <%
            // 使用 date helper 格式化，保持原始日期不变
            var dateStr = date(p.date, 'YYYY-MM-DD');
            var displayDate = date(p.date, 'YYYY年MM月DD日');
            // 提取标签名称
            var tagNames = [];
            if (p.tags && p.tags.length > 0) {
              p.tags.forEach(function(tag) {
                tagNames.push(typeof tag === 'string' ? tag : tag.name);
              });
            }
          %>
          <article class="timeline-item" data-date="<%= dateStr %>" data-tags="<%= tagNames.join(',') %>">
            <time class="timeline-date"><%= displayDate %></time>
            <div class="timeline-content">
              <h3 class="timeline-title"><%- p.title %></h3>
              <div class="timeline-body"><%- p.content %></div>
              <% if (p.tags && p.tags.length > 0) { %>
              <div class="timeline-tags">
                <% p.tags.forEach(function(tag) { %>
                <% var tagName = typeof tag === 'string' ? tag : tag.name; %>
                <span class="timeline-tag" data-tag="<%= tagName %>">#<%= tagName %></span>
                <% }); %>
              </div>
              <% } %>
            </div>
          </article>
        <% }); %>
      </div>
    </div>
  </div>
</div>

<style>
.flow-page { max-width: 1200px; margin: 0 auto; }
.flow-description { color: var(--color-text-secondary); margin-bottom: 2rem; }
.flow-layout { display: grid; grid-template-columns: 280px 1fr; gap: 2rem; align-items: start; }
.calendar-sidebar { position: sticky; top: 90px; }
.calendar-container { background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 8px; padding: 1rem; }
.calendar-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
.calendar-title { font-size: 0.95rem; font-weight: 600; }
.calendar-nav { background: var(--color-hover); border: 1px solid var(--color-border); width: 28px; height: 28px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.calendar-nav:hover { background: var(--color-accent); color: var(--color-bg); }
.calendar-grid { width: 100%; }
.calendar-weekdays { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; margin-bottom: 0.25rem; }
.calendar-weekdays span { text-align: center; font-size: 0.7rem; color: var(--color-text-secondary); padding: 0.25rem; }
.calendar-days { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
.calendar-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; border-radius: 4px; cursor: pointer; position: relative; }
.calendar-day.has-content { font-weight: 600; }
.calendar-day.has-content::after { content: ''; position: absolute; bottom: 2px; width: 4px; height: 4px; border-radius: 50%; background: var(--color-accent); }
.calendar-day.has-content:hover { background: var(--color-accent); color: var(--color-bg); }
.calendar-day.selected { background: var(--color-accent); color: var(--color-bg); }
.filter-status { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--color-border); }
.clear-filter-btn { background: var(--color-hover); border: 1px solid var(--color-border); padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; cursor: pointer; }
.clear-filter-btn:hover { background: var(--color-accent); color: var(--color-bg); }
.timeline-wrapper { min-width: 0; }
.timeline { position: relative; padding-left: 2rem; }
.timeline::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--color-border), var(--color-accent), var(--color-border)); }
.timeline-item { position: relative; padding-bottom: 2rem; }
.timeline-item:last-child { padding-bottom: 0; }
.timeline-item::before { content: ''; position: absolute; left: -2rem; top: 0.5rem; width: 12px; height: 12px; border-radius: 50%; background: var(--color-bg); border: 2px solid var(--color-accent); transform: translateX(-5px); }
.timeline-item:hover::before { background: var(--color-accent); }
.timeline-content { background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 8px; padding: 1.25rem; transition: transform 0.2s }
.timeline-item:hover .timeline-content { transform: translateX(4px) }
.timeline-title { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.75rem }
.timeline-body { line-height: 1.7 }
.timeline-tags { margin-top: 0.75rem; display: flex; flex-wrap: wrap; gap: 0.5rem }
.timeline-tag { font-size: 0.75rem; color: var(--color-text-secondary); background: var(--color-hover); padding: 0.2rem 0.5rem; border-radius: 4px }
.timeline-item.hidden { display: none }
@media (max-width: 900px) {
  .flow-layout { grid-template-columns: 1fr }
  .calendar-sidebar { position: static }
  .calendar-container { max-width: 360px; margin: 0 auto 2rem }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log('[Flow Calendar] DOMContentLoaded fired')
  var items = document.querySelectorAll('.timeline-item')
  console.log('[Flow Calendar] Found timeline items:', items.length)
  var contentDates = []
  items.forEach(function(item) {
    var date = item.getAttribute('data-date')
    if (date) contentDates.push(date)
  })
  console.log('[Flow Calendar] contentDates:', contentDates)
  // 按日期排序（从新到旧）
  contentDates.sort(function(a, b) {
    return new Date(b) - new Date(a)
  })
  // 使用最新的flow记录的日期来初始化日历
  var currentDate = contentDates.length > 0 ? new Date(contentDates[0]) : new Date()
  console.log('[Flow Calendar] Initial calendar date:', currentDate.toISOString())
  var selectedDate = null
  function renderCalendar(date) {
    console.log('[Flow Calendar] renderCalendar called with:', date.toISOString())
    var year = date.getFullYear()
    var month = date.getMonth()
    console.log('[Flow Calendar] Rendering', year, 'year', month, 'month (0-indexed)')
    document.getElementById('calendarTitle').textContent = year + '年' + (month + 1) + '月'
    var firstDay = new Date(year, month, 1)
    var lastDay = new Date(year, month + 1, 0)
    var daysInMonth = lastDay.getDate()
    var startWeekday = firstDay.getDay()
    console.log('[Flow Calendar] Month has', daysInMonth, 'days, starting on weekday', startWeekday)
    var daysContainer = document.getElementById('calendarDays')
    if (!daysContainer) {
      console.error('[Flow Calendar] ERROR: calendarDays container not found!')
      return
    }
    daysContainer.innerHTML = ''
    for (var i = startWeekday - 1; i >= 0; i--) {
      var btn = document.createElement('button')
      btn.className = 'calendar-day'
      btn.style.opacity = '0.3'
      btn.disabled = true
      daysContainer.appendChild(btn)
    }
    var markedDays = 0
    for (var day = 1; day <= daysInMonth; day++) {
      var dateStr = formatDate(year, month, day)
      var hasContent = contentDates.indexOf(dateStr) !== -1
      if (hasContent) markedDays++
      var btn = document.createElement('button')
      btn.className = 'calendar-day'
      if (hasContent) btn.classList.add('has-content')
      btn.textContent = day
      // 使用闭包正确捕获 dateStr 值
      if (hasContent) {
        (function(ds) {
          btn.addEventListener('click', function() {
            console.log('[Flow Calendar] Clicked date:', ds)
            filterContent(ds)
          })
        })(dateStr)
      }
      if (selectedDate === dateStr) btn.classList.add('selected')
      daysContainer.appendChild(btn)
    }
    console.log('[Flow Calendar] Calendar rendered with', markedDays, 'marked days')
  }
  function formatDate(year, month, day) {
    return year + '-' + String(month + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0')
  }
  function filterContent(dateStr) {
    console.log('[Flow Calendar] filterContent called with:', dateStr)
    document.querySelectorAll('.calendar-day.selected').forEach(function(el) { el.classList.remove('selected') })
    selectedDate = dateStr
    document.querySelectorAll('.calendar-day').forEach(function(el) {
      if (el.textContent === parseInt(dateStr.split('-')[2]) && el.classList.contains('has-content')) el.classList.add('selected')
    })
    var allItems = document.querySelectorAll('.timeline-item')
    var visibleCount = 0
    allItems.forEach(function(item) {
      if (item.getAttribute('data-date') === dateStr) {
        item.classList.remove('hidden')
        visibleCount++
      } else {
        item.classList.add('hidden')
      }
    })
    console.log('[Flow Calendar] Filtered to show', visibleCount, 'items')
    document.getElementById('filterStatus').style.display = 'flex'
  }
  function clearFilter() {
    selectedDate = null
    document.querySelectorAll('.timeline-item').forEach(function(item) { item.classList.remove('hidden') })
    document.getElementById('filterStatus').style.display = 'none'
  }
  document.getElementById('prevMonth').addEventListener('click', function() {
    currentDate.setMonth(currentDate.getMonth() - 1)
    renderCalendar(currentDate)
  })
  document.getElementById('nextMonth').addEventListener('click', function() {
    currentDate.setMonth(currentDate.getMonth() + 1)
    renderCalendar(currentDate)
  })
  document.getElementById('clearFilter').addEventListener('click', clearFilter)
  renderCalendar(currentDate)

  // 标签过滤功能
  var selectedTag = null
  var timeline = document.getElementById('timeline')

  timeline.addEventListener('click', function(e) {
    if (e.target.classList.contains('timeline-tag')) {
      e.preventDefault()
      var tagName = e.target.getAttribute('data-tag')
      filterByTag(tagName)
    }
  })

  function filterByTag(tagName) {
    console.log('[Flow Tags] Filtering by tag:', tagName)
    selectedTag = tagName
    var items = timeline.querySelectorAll('.timeline-item')
    var tags = timeline.querySelectorAll('.timeline-tag')

    // 更新标签选中状态
    tags.forEach(function(tag) {
      if (tag.getAttribute('data-tag') === tagName) {
        tag.classList.add('active')
      } else {
        tag.classList.remove('active')
      }
    })

    // 过滤项目
    var visibleCount = 0
    items.forEach(function(item) {
      var itemTags = item.getAttribute('data-tags')
      if (itemTags && itemTags.split(',').indexOf(tagName) !== -1) {
        item.classList.remove('tag-hidden')
        item.classList.remove('hidden') // 也移除日期过滤的hidden
        visibleCount++
      } else {
        item.classList.add('tag-hidden')
      }
    })

    // 显示过滤状态
    var filterStatus = document.getElementById('filterStatus')
    var filterText = document.getElementById('filterText')
    if (filterStatus && filterText) {
      filterText.textContent = '标签: #' + tagName + ' (' + visibleCount + ')'
      filterStatus.style.display = 'flex'
    }

    console.log('[Flow Tags] Filtered to show', visibleCount, 'items')
  }

  function clearTagFilter() {
    console.log('[Flow Tags] Clearing tag filter')
    selectedTag = null
    var items = timeline.querySelectorAll('.timeline-item')
    var tags = timeline.querySelectorAll('.timeline-tag')

    items.forEach(function(item) {
      item.classList.remove('tag-hidden')
    })

    tags.forEach(function(tag) {
      tag.classList.remove('active')
    })
  }

  // 修改原有的clearFilter函数，同时清除日期和标签过滤
  var originalClearFilter = clearFilter
  clearFilter = function() {
    originalClearFilter()
    clearTagFilter()
  }
})
</script>

<style>
.timeline-tag {
  cursor: pointer;
  transition: all var(--transition);
}

.timeline-tag:hover {
  background: var(--color-accent) !important;
  color: var(--color-bg) !important;
}

.timeline-tag.active {
  background: var(--color-accent) !important;
  color: var(--color-bg) !important;
  font-weight: 600;
}

.timeline-item.tag-hidden {
  display: none !important;
}
</style>

