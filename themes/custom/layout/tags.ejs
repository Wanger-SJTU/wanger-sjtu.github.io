<!-- 标签列表页模板 -->
<div class="tag-page">
  <h1 class="page-title">标签</h1>

  <div class="tag-stats">
    共 <span class="stat-number"><%= site.tags.length %></span> 个标签，
    <span class="stat-number"><%= site.posts.length %></span> 篇文章
  </div>

  <div class="tag-grid">
    <% site.tags.sort('posts.length', -1).each(function(tag) { %>
    <a href="<%= url_for(tag.path) %>" class="tag-card">
      <div class="tag-card-header">
        <span class="tag-name"><%= tag.name %></span>
        <span class="tag-count"><%= tag.posts.length %></span>
      </div>
      <div class="tag-card-footer">
        <span class="tag-label">篇文章</span>
      </div>
    </a>
    <% }); %>
  </div>
</div>

<style>
.tag-page .page-title + .tag-stats {
  margin-top: 1rem;
}
</style>
