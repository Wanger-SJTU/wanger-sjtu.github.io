<!-- 标签列表页模板 -->
<div class="tag-page">
  <h1 class="page-title">标签</h1>
  
  <div class="tag-cloud">
    <% site.tags.sort('name').each(function(tag) { %>
    <a href="<%= url_for(tag.path) %>" class="tag-item" style="font-size: <%= Math.min(1 + tag.posts.length * 0.1, 2) %>em">
      <span class="tag-name"><%= tag.name %></span>
      <span class="tag-count">(<%= tag.posts.length %>)</span>
    </a>
    <% }); %>
  </div>
</div>
