<!-- 标签列表页模板 -->
<div class="tag-page">
  <h1 class="page-title">标签</h1>
  
  <div class="tag-cloud">
    <% site.tags.sort('name').each(function(tag) { %>
    <a href="<%= url_for(tag.path) %>" class="tag-item" style="font-size: <%= Math.min(1 + tag.posts.length * 0.1, 2) %>em">
      <span class="tag-name"><%= tag.name %></span>
      <span class="tag-count">(<%= tag.posts.length %>)</span>
    </a>
    <% }); %>
  </div>
  
  <h2 class="page-title" style="margin-top: 3rem;">文章图谱</h2>
  <div id="article-graph" style="width: 100%; height: 600px; border: 1px solid var(--color-border); border-radius: var(--radius); margin-top: 1rem;"></div>
</div>

<!-- Vis.js Network -->
<script src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
<script>
<% 
// 过滤掉废话文章
var filteredPosts = site.posts.filter(function(post) {
  var isNonsense = false;
  if (post.categories && post.categories.length) {
    post.categories.each(function(cat) {
      if (cat.name === '废话') {
        isNonsense = true;
      }
    });
  }
  return !isNonsense;
});

// 生成节点数据
var nodes = [];
var nodeMap = {};
var postTags = {};

filteredPosts.sort('date', -1).each(function(post) {
  var tagCount = post.tags ? post.tags.length : 0;
  var node = {
    id: post._id,
    label: post.title,
    title: post.title + (post.tags ? ' (' + post.tags.toArray().map(function(t) { return t.name; }).join(', ') + ')' : ''),
    value: tagCount + 1,
    url: config.root + post.path
  };
  nodes.push(node);
  nodeMap[post._id] = node;
  
  // 记录每篇文章的标签
  if (post.tags && post.tags.length) {
    postTags[post._id] = post.tags.toArray().map(function(t) { return t.name; });
  }
});

// 生成边数据（基于共享标签）
var edges = [];
var edgeMap = {};

for (var i in postTags) {
  for (var j in postTags) {
    if (i >= j) continue;
    
    var tags1 = postTags[i];
    var tags2 = postTags[j];
    var sharedTags = tags1.filter(function(tag) { return tags2.indexOf(tag) !== -1; });
    
    if (sharedTags.length > 0) {
      var edgeId = i + '-' + j;
      if (!edgeMap[edgeId]) {
        edges.push({
          from: i,
          to: j,
          value: sharedTags.length,
          title: '共享标签: ' + sharedTags.join(', ')
        });
        edgeMap[edgeId] = true;
      }
    }
  }
}
%>

// 获取当前主题
var isDarkMode = document.documentElement.getAttribute('data-theme') === 'dark';

// 节点颜色
var nodeColor = isDarkMode ? {
  background: '#ffffff',
  border: '#666666',
  highlight: { background: '#f0f0f0', border: '#333333' },
  hover: { background: '#e0e0e0', border: '#333333' }
} : {
  background: '#f8f8f8',
  border: '#333333',
  highlight: { background: '#e0e0e0', border: '#000000' },
  hover: { background: '#d0d0d0', border: '#000000' }
};

// 创建节点数据集
var nodesDataset = new vis.DataSet(<%- JSON.stringify(nodes) %>);

// 创建边数据集
var edgesDataset = new vis.DataSet(<%- JSON.stringify(edges) %>);

// 创建网络
var container = document.getElementById('article-graph');
var data = {
  nodes: nodesDataset,
  edges: edgesDataset
};

var options = {
  nodes: {
    shape: 'dot',
    color: nodeColor,
    font: {
      size: 14,
      color: isDarkMode ? '#cccccc' : '#333333'
    },
    borderWidth: 2,
    shadow: false
  },
  edges: {
    color: {
      color: isDarkMode ? 'rgba(255, 255, 255, 0.2)' : 'rgba(0, 0, 0, 0.2)',
      highlight: isDarkMode ? 'rgba(255, 255, 255, 0.5)' : 'rgba(0, 0, 0, 0.5)',
      hover: isDarkMode ? 'rgba(255, 255, 255, 0.3)' : 'rgba(0, 0, 0, 0.3)'
    },
    width: 0.5,
    smooth: {
      type: 'continuous'
    }
  },
  physics: {
    stabilization: true,
    barnesHut: {
      gravitationalConstant: -3000,
      centralGravity: 0.3,
      springLength: 200,
      springConstant: 0.05
    }
  },
  interaction: {
    hover: true,
    tooltipDelay: 200,
    zoomView: true,
    dragView: true
  }
};

var network = new vis.Network(container, data, options);

// 点击节点跳转到文章
network.on('click', function(params) {
  if (params.nodes.length > 0) {
    var nodeId = params.nodes[0];
    var node = nodesDataset.get(nodeId);
    if (node.url) {
      window.location.href = node.url;
    }
  }
});

// 监听主题变化
var observer = new MutationObserver(function(mutations) {
  mutations.forEach(function(mutation) {
    if (mutation.attributeName === 'data-theme') {
      var newDarkMode = document.documentElement.getAttribute('data-theme') === 'dark';
      var newNodeColor = newDarkMode ? {
        background: '#ffffff',
        border: '#666666',
        highlight: { background: '#f0f0f0', border: '#333333' },
        hover: { background: '#e0e0e0', border: '#333333' }
      } : {
        background: '#f8f8f8',
        border: '#333333',
        highlight: { background: '#e0e0e0', border: '#000000' },
        hover: { background: '#d0d0d0', border: '#000000' }
      };
      
      var newEdgeColor = newDarkMode ? {
        color: 'rgba(255, 255, 255, 0.2)',
        highlight: 'rgba(255, 255, 255, 0.5)',
        hover: 'rgba(255, 255, 255, 0.3)'
      } : {
        color: 'rgba(0, 0, 0, 0.2)',
        highlight: 'rgba(0, 0, 0, 0.5)',
        hover: 'rgba(0, 0, 0, 0.3)'
      };
      
      nodesDataset.forEach(function(node) {
        nodesDataset.update({ id: node.id, color: newNodeColor, font: { color: newDarkMode ? '#cccccc' : '#333333' } });
      });
      
      edgesDataset.forEach(function(edge) {
        edgesDataset.update({ id: edge.id, color: newEdgeColor });
      });
    }
  });
});

observer.observe(document.documentElement, { attributes: true });
</script>
